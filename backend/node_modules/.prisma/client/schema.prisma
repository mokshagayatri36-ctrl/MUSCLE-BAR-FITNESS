datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     String @default("MEMBER") // "ADMIN" or "MEMBER"
}

model MembershipPlan {
  id       String @id @default(uuid())
  name     String
  duration String
  price    Float
  benefits String // Stored as a newline-separated string
}

model Trainer {
  id             String @id @default(uuid())
  name           String
  photo          String
  experience     String
  certifications String // Newline-separated
  achievements   String // Newline-separated
}

model Program {
  id          String @id @default(uuid())
  title       String
  description String
  duration    String
  benefits    String // Newline-separated
}

model Gallery {
  id       String @id @default(uuid())
  imageUrl String
  category String // "Interior", "Equipment", "Sessions", "Transformations"
}

model Enquiry {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String
  plan      String
  message   String
  createdAt DateTime @default(now())
}

model Registration {
  id           String   @id @default(uuid())
  name         String
  gender       String
  age          Int
  phone        String
  email        String
  address      String
  selectedPlan String
  status       String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdAt    DateTime @default(now())
}

model Feedback {
  id             String   @id @default(uuid())
  name           String
  rating         Int
  review         String
  approvalStatus String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdAt      DateTime @default(now())
}

model Payment {
  id          String   @id @default(uuid())
  memberName  String
  plan        String
  amount      Float
  paymentDate DateTime @default(now())
  status      String   @default("PENDING") // "PENDING", "PAID"
}
